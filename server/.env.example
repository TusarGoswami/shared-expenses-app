# PostgreSQL connection string (Neon, Supabase, or local instance)
DATABASE_URL=postgresql://<username>:<password>@<host>:<port>/<dbname>?sslmode=require

# JWT secret key — use a strong random string (e.g. openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_key_here

# Server port
PORT=5000

# Fixed USD to INR exchange rate used for currency conversion at import time
USD_TO_INR_RATE=83.50
